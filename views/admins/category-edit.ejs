<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    
    <%- include('../partials/nav') %>

    <div class="container mt-3">
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    <input type="hidden" name="categoryid" value="<%= category.categoryid %>">
                    <div class="row mb-3">
                        <label for="baslik" class="col-sm-2 col-form-label">Başlık</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control" id="baslik" name="baslik" value="<%= category.categoryname %>">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
                </form>
            </div>
            <p>Toplam Blog Sayısı = <%= blogCount %></p>
            <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th style="width: 75px;">id</th>
                            <th style="width: 150px;">resim</th>
                            <th>baslik</th>
                            <th style="width: 150px;">işlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% blogs.forEach(blog => { %>
                            <tr>
                                <td><%= blog.blogid %></td>
                                <td>
                                    <img src="/static/images/<%= blog.resim %>" class="img-fluid" alt="">
                                </td>                                
                                <td>
                                    <h5><%= blog.baslik %></h5>
                                    <br>
                                    <%= blog.altbaslik %>
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-primary" href="/admin/blogs/<%= blog.blogid %>">Edit</a>
                                    <a class="btn btn-sm btn-danger" href="/admin/blog/delete/<%= blog.blogid %>">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
        </div>
    </div>

</body>
</html>